# 正向 WebSocket：NoneBot 作为客户端连接 NapCat 监听的地址（先启动 NapCat，再启动本进程）
DRIVER=~fastapi+~websockets

ONEBOT_WS_URLS=["ws://127.0.0.1:18881"]
# 若 NapCat 启用了 access token，填写与 NapCat 一致；无则留空
ONEBOT_ACCESS_TOKEN=

HOST=127.0.0.1
# 与 NapCat 无关；仅本机 HTTP 服务端口。被占用时换端口，见 README
PORT=18080

# 群聊白名单 INI（默认项目根目录下 group_whitelist.ini）；仅白名单内且 @ 机器人才回复
# GROUP_WHITELIST_INI=group_whitelist.ini

# 大模型后端切换（默认 llm_config.ini）：openclaw / local
# LLM_CONFIG_INI=llm_config.ini
